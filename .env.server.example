# MultiWA server env template.
# Copy to an ignored local env file such as .env.pln-batam.local and fill real values there.
# Files matching .env.*.local are ignored by git.

NODE_ENV=production

# Public/API reachability for Link checks.
MULTIWA_BASE_URL=https://multiwa.example.internal
NEXT_PUBLIC_API_URL=https://multiwa.example.internal

# Server-side runtime dependencies.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
REDIS_URL=redis://:PASSWORD@HOST:6379

# Auth/runtime secrets.
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# API binding if this env is used on the server.
API_HOST=0.0.0.0
API_PORT=3333
ADMIN_PORT=3001
CORS_ORIGINS=https://multiwa.example.internal

# WhatsApp runtime.
DEFAULT_ENGINE=whatsapp-web-js
SESSIONS_DIR=/data/sessions
PUPPETEER_HEADLESS=true
PUPPETEER_NO_SANDBOX=true

# Storage.
STORAGE_TYPE=local
STORAGE_PATH=/data/uploads
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=

# Webhooks.
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_RETRY_ATTEMPTS=5
WEBHOOK_RETRY_DELAY_MS=30000
