<%- include('header') %>

<div class="dashboard-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div style="text-align: center; margin-bottom: 2rem;">
            <h3 style="color: var(--primary-dark)"><%= user.username %></h3>
            <span id="connectionBadge" class="badge badge-danger">غير متصل</span>
        </div>
        <ul class="sidebar-nav">
            <li><a href="#" class="active" onclick="showTab('connectTab', this)">ربط الواتساب</a></li>
            <li><a href="#" onclick="showTab('sendTab', this)">إرسال رسالة</a></li>
            <li><a href="#" onclick="showTab('historyTab', this)">أرشيف الرسائل</a></li>
            <li><a href="#" id="logoutWaBtn" style="color: var(--danger)">فصل الواتساب</a></li>
            <li><a href="#" id="logoutBtn" style="color: var(--text-muted); margin-top: 2rem;">تسجيل الخروج</a></li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <!-- Connect Tab -->
        <div id="connectTab" class="tab-content">
            <h2 class="mb-4">إعدادات الربط</h2>
            <div id="statusContainer" class="mb-4">
                <p>حالة الواتساب: <strong id="waStatusText">غير متصل</strong></p>
                <button id="startConnectBtn" class="btn-primary mt-4">توليد كود الربط وبدء الجلسة</button>
            </div>
            
            <div id="qrSection" class="hidden text-center mt-4">
                <h3 class="mb-3">طريقة 1: مسح كود QR</h3>
                <div style="background: white; padding: 20px; display: inline-block; border-radius: 10px; margin-bottom: 20px;">
                    <img id="qrImage" src="" alt="QR Code" style="width: 250px; height: 250px;">
                </div>
                
                <hr style="margin: 20px 0; border: 0; border-top: 1px solid #e2e8f0;">

                <h3 class="mb-3">طريقة 2: الربط بالرمز الرقمي (Pairing Code)</h3>
                <div style="max-width: 300px; margin: 0 auto;">
                    <input type="text" id="phoneNumberCode" class="form-control mb-3" placeholder="رقم الهاتف (بدون +)">
                    <button id="requestCodeBtn" class="btn-primary" style="width: 100%">طلب الرمز الرقمي</button>
                </div>
                <div id="pairingCodeDisplay" class="hidden mt-4" style="font-size: 2rem; letter-spacing: 5px; font-weight: bold; color: var(--primary-dark);">
                    <!-- Code here -->
                </div>
            </div>
        </div>

        <!-- Send Tab -->
        <div id="sendTab" class="tab-content hidden">
            <h2 class="mb-4">إرسال رسالة جديدة</h2>
            <% if(user.can_send_messages === 1) { %>
                <form id="sendMessageForm">
                    <div class="form-group">
                        <label class="mb-1" style="display: block; font-weight: bold;">رقم المستلم (مع رمز الدولة بدون +)</label>
                        <input type="text" id="recvPhone" class="form-control" required placeholder="مثال: 966500000000">
                    </div>
                    <div class="form-group">
                        <label class="mb-1" style="display: block; font-weight: bold;">الرسالة</label>
                        <textarea id="msgContent" class="form-control" rows="4" required></textarea>
                    </div>
                    <div class="form-group">
                        <label class="mb-1" style="display: block; font-weight: bold;">إرفاق ملف (اختياري)</label>
                        <input type="file" id="msgFile" class="form-control">
                    </div>
                    <button type="submit" class="btn-primary mt-4">إرسال الآن <span id="sendLoader" class="hidden">...</span></button>
                </form>
            <% } else { %>
                <div style="background: #fed7d7; color: #822727; padding: 20px; border-radius: 12px;">
                    عذراً، حسابك لا يمتلك صلاحية الإرسال حالياً. يرجى مراجعة الإدارة.
                </div>
            <% } %>
        </div>

        <!-- History Tab -->
        <div id="historyTab" class="tab-content hidden">
            <h2 class="mb-4">أرشيف الرسائل</h2>
            <div style="overflow-x: auto;">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>الرقم</th>
                            <th>الرسالة</th>
                            <th>المرفق</th>
                            <th>الحالة</th>
                            <th>التاريخ</th>
                        </tr>
                    </thead>
                    <tbody id="historyTable">
                        <!-- Filled by JS -->
                    </tbody>
                </table>
            </div>
        </div>

    </main>
</div>

<script>
const userId = <%= user.id %>;
const socket = io();

// Tabs Logic
function showTab(tabId, el) {
    document.querySelectorAll('.tab-content').forEach(t => t.classList.add('hidden'));
    document.getElementById(tabId).classList.remove('hidden');
    document.querySelectorAll('.sidebar-nav a').forEach(a => a.classList.remove('active'));
    el.classList.add('active');

    if(tabId === 'historyTab') loadHistory();
}

// Socket IO logic for Real-time WhatsApp updates
socket.emit('join_room', userId);

socket.on('status_update', (status) => {
    document.getElementById('waStatusText').innerText = status;
    const badge = document.getElementById('connectionBadge');
    
    if(status === 'connected') {
        badge.innerText = 'متصل';
        badge.className = 'badge badge-success';
        document.getElementById('qrSection').classList.add('hidden');
        document.getElementById('startConnectBtn').classList.add('hidden');
        Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'تم الربط بنجاح!', showConfirmButton: false, timer: 2000 });
    } else if (status === 'qr_ready') {
        badge.innerText = 'في انتظار المسح';
        badge.className = 'badge badge-warning';
        document.getElementById('qrSection').classList.remove('hidden');
        document.getElementById('startConnectBtn').classList.add('hidden');
    } else {
        badge.innerText = 'غير متصل';
        badge.className = 'badge badge-danger';
        document.getElementById('qrSection').classList.add('hidden');
        document.getElementById('startConnectBtn').classList.remove('hidden');
    }
});

socket.on('qr_update', (qrDataUrl) => {
    document.getElementById('qrImage').src = qrDataUrl;
});

socket.on('pairing_code_update', (code) => {
    const disp = document.getElementById('pairingCodeDisplay');
    disp.innerText = code.match(/.{1,4}/g).join('-'); // Format code
    disp.classList.remove('hidden');
});

// Initialize Session
document.getElementById('startConnectBtn').addEventListener('click', async () => {
    await fetch('/api/wa/connect', { method: 'POST' });
});

// Request Pairing Code
document.getElementById('requestCodeBtn').addEventListener('click', async () => {
    const phone = document.getElementById('phoneNumberCode').value;
    if(!phone) return Swal.fire('تنبيه', 'يرجى إدخال رقم الهاتف', 'warning');
    try {
        const res = await fetch('/api/wa/pairing-code', {
            method: 'POST',
            headers: {'Content-Type':'application/json'},
            body: JSON.stringify({ phone })
        });
        const data = await res.json();
        if(data.error) Swal.fire('خطأ', data.error, 'error');
    } catch(err) {
        Swal.fire('خطأ', 'حدث خطأ', 'error');
    }
});

// Send Message
<% if(user.can_send_messages === 1) { %>
document.getElementById('sendMessageForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = e.target.querySelector('button');
    btn.disabled = true;
    
    const formData = new FormData();
    formData.append('phone', document.getElementById('recvPhone').value);
    formData.append('content', document.getElementById('msgContent').value);
    const file = document.getElementById('msgFile').files[0];
    if(file) formData.append('media', file);

    try {
        const res = await fetch('/api/messages/send', {
            method: 'POST',
            body: formData
        });
        const data = await res.json();
        if(res.ok) {
            Swal.fire('نجاح', 'تم الإرسال', 'success');
            e.target.reset();
        } else {
            Swal.fire('خطأ', data.error, 'error');
        }
    } catch(err) {
        Swal.fire('خطأ', 'حدث خطأ في الاتصال', 'error');
    }
    btn.disabled = false;
});
<% } %>

// Load History
async function loadHistory() {
    const res = await fetch('/api/messages/history');
    const msgs = await res.json();
    const tbody = document.getElementById('historyTable');
    tbody.innerHTML = '';
    msgs.forEach(m => {
        tbody.innerHTML += `
            <tr>
                <td dir="ltr" style="text-align: right">${m.phone_number}</td>
                <td>${m.content || 'لا يوجد نص'}</td>
                <td>${m.media_path ? '<span class="badge badge-success">نعم</span>' : '<span class="badge badge-warning">لا</span>'}</td>
                <td>${m.status === 'success' ? '<span class="badge badge-success">ناجح</span>' : '<span class="badge badge-danger">فشل</span>'}</td>
                <td dir="ltr" style="text-align: right">${new Date(m.created_at).toLocaleString('ar-SA')}</td>
            </tr>
        `;
    });
}

// Fetch Initial Status
fetch('/api/wa/status').then(r=>r.json()).then(data => {
    if(data.status === 'connected') {
        document.getElementById('connectionBadge').innerText = 'متصل';
        document.getElementById('connectionBadge').className = 'badge badge-success';
        document.getElementById('startConnectBtn').classList.add('hidden');
    } else if (data.status === 'qr_ready') {
        document.getElementById('connectionBadge').innerText = 'في انتظار المسح';
        document.getElementById('connectionBadge').className = 'badge badge-warning';
        document.getElementById('qrImage').src = data.qr;
        document.getElementById('qrSection').classList.remove('hidden');
        document.getElementById('startConnectBtn').classList.add('hidden');
    }
});

// Logout APIs
document.getElementById('logoutWaBtn').addEventListener('click', async () => {
    if(confirm('هل تريد فصل اتصال الواتساب؟')) {
        await fetch('/api/wa/logout', { method: 'POST' });
        window.location.reload();
    }
});

document.getElementById('logoutBtn').addEventListener('click', async () => {
    await fetch('/api/logout', { method: 'POST' });
    window.location.href = '/login';
});
</script>

<%- include('footer') %>
