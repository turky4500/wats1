<% locals.adminTab = 'overview'; locals.pageTitle = 'نظرة عامة'; %>
<%- include('../partials/admin_sidebar') %>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
    <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-bold text-slate-400 uppercase mb-1">المستخدمون</p>
        <h3 class="text-4xl font-black text-slate-900 dark:text-white"><%= usersCount %></h3>
    </div>
    <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-bold text-slate-400 uppercase mb-1">أجهزة متصلة</p>
        <h3 class="text-4xl font-black text-whatsapp"><%= connectedDevices %></h3>
    </div>
    <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-bold text-slate-400 uppercase mb-1">الحملات</p>
        <h3 class="text-4xl font-black text-slate-900 dark:text-white"><%= campaigns.length %></h3>
    </div>
    <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200 dark:border-slate-800 shadow-sm">
        <p class="text-xs font-bold text-slate-400 uppercase mb-1">إجمالي الأجهزة</p>
        <h3 class="text-4xl font-black text-slate-900 dark:text-white"><%= devices.length %></h3>
    </div>
</div>

<!-- Recent Users -->
<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
        <h2 class="font-black text-lg">أحدث المستخدمين</h2>
        <a href="/admin/users" class="text-sm text-whatsapp font-bold hover:underline">عرض الكل</a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-slate-800/50">
                <tr>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">#</th>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">المستخدم</th>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">البريد</th>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">الباقة</th>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">الدور</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                <% users.slice(0,5).forEach(u => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                    <td class="px-6 py-4 text-slate-400"><%= u.id %></td>
                    <td class="px-6 py-4 font-bold"><%= u.username %></td>
                    <td class="px-6 py-4 text-slate-500"><%= u.email %></td>
                    <td class="px-6 py-4"><span class="px-2 py-1 bg-emerald-100 text-emerald-700 rounded-lg text-xs font-bold"><%= u.plan_name || 'Starter' %></span></td>
                    <td class="px-6 py-4">
                        <% if(u.role === 'admin') { %>
                            <span class="px-2 py-1 bg-red-100 text-red-700 rounded-lg text-xs font-bold">مدير</span>
                        <% } else { %>
                            <span class="px-2 py-1 bg-slate-100 text-slate-600 rounded-lg text-xs font-bold">مستخدم</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
                <% if(users.length === 0) { %>
                <tr><td colspan="5" class="text-center py-8 text-slate-400">لا يوجد مستخدمون بعد</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<!-- Recent Devices -->
<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
        <h2 class="font-black text-lg">أحدث الأجهزة</h2>
        <a href="/admin/devices" class="text-sm text-whatsapp font-bold hover:underline">عرض الكل</a>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-slate-800/50">
                <tr>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">اسم الجهاز</th>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">رقم الجوال</th>
                    <th class="text-right px-6 py-3 font-bold text-slate-500">الحالة</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                <% devices.slice(0,5).forEach(d => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                    <td class="px-6 py-4 font-bold"><%= d.name %></td>
                    <td class="px-6 py-4 text-slate-500"><%= d.phone_number || '—' %></td>
                    <td class="px-6 py-4">
                        <span class="px-2 py-1 rounded-lg text-xs font-bold <%= d.status === 'connected' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-600' %>">
                            <%= d.status === 'connected' ? 'متصل' : 'مفصول' %>
                        </span>
                    </td>
                </tr>
                <% }) %>
                <% if(devices.length === 0) { %>
                <tr><td colspan="3" class="text-center py-8 text-slate-400">لا توجد أجهزة بعد</td></tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/admin_footer') %>
