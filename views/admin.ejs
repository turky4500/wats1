<%- include('header') %>

<div class="dashboard-layout">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div style="text-align: center; margin-bottom: 2rem;">
            <h3 style="color: var(--primary-dark)">المدير: <%= user.username %></h3>
            <span class="badge badge-warning">لوحة التحكم</span>
        </div>
        <ul class="sidebar-nav">
            <li><a href="#" class="active">إدارة المستخدمين</a></li>
            <li><a href="#" id="logoutBtn" style="color: var(--danger)">تسجيل الخروج</a></li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <h2 class="mb-4">إدارة مستخدمي النظام</h2>
        <div style="overflow-x: auto;">
            <table class="premium-table">
                <thead>
                    <tr>
                        <th>الرقم</th>
                        <th>اسم المستخدم</th>
                        <th>تاريخ الإنشاء</th>
                        <th>صلاحية الإرسال</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody id="usersTable">
                    <!-- Users injected via JS -->
                </tbody>
            </table>
        </div>
    </main>
</div>

<script>
async function loadUsers() {
    const res = await fetch('/api/admin/users');
    const users = await res.json();
    const tbody = document.getElementById('usersTable');
    tbody.innerHTML = '';

    users.forEach(u => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
            <td>#${u.id}</td>
            <td>${u.username}</td>
            <td>${new Date(u.created_at).toLocaleDateString('ar-SA')}</td>
            <td>
                <label class="toggle-switch">
                    <input type="checkbox" onchange="togglePermission(${u.id}, this.checked)" ${u.can_send_messages ? 'checked' : ''}>
                    <span class="slider"></span>
                </label>
            </td>
            <td>
                <button class="btn-danger" onclick="deleteUser(${u.id})">حذف</button>
            </td>
        `;
        tbody.appendChild(tr);
    });
}

async function togglePermission(id, status) {
    await fetch(`/api/admin/users/${id}/toggle-permission`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ can_send_messages: status })
    });
    Swal.fire({
        toast: true,
        position: 'top-end',
        icon: 'success',
        title: 'تم تحديث الصلاحية',
        showConfirmButton: false,
        timer: 1500
    });
}

async function deleteUser(id) {
    if(confirm('هل أنت متأكد من حذف هذا المستخدم نهائياً؟')) {
        await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
        loadUsers();
    }
}

document.getElementById('logoutBtn').addEventListener('click', async () => {
    await fetch('/api/logout', { method: 'POST' });
    window.location.href = '/login';
});

loadUsers();
</script>

<%- include('footer') %>
