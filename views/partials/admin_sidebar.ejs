<!DOCTYPE html>
<html lang="ar" dir="rtl" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>لوحة الإدارة | إيزي واتس</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
    </script>
</head>
<body class="bg-slate-50 text-slate-900 font-arabic dark:bg-slate-950 dark:text-white">
<div class="flex h-screen overflow-hidden">

    <!-- Sidebar -->
    <aside class="w-64 bg-white dark:bg-slate-900 border-l border-slate-200 dark:border-slate-800 flex flex-col shrink-0">
        <div class="h-16 flex items-center justify-center border-b border-slate-200 dark:border-slate-800">
            <span class="text-xl font-black text-red-500"><i class="fa-solid fa-shield-halved ml-2"></i>لوحة الإدارة</span>
        </div>
        <nav class="p-4 flex-1 space-y-1">
            <a href="/admin" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-bold <%= locals.adminTab === 'overview' ? 'bg-red-50 text-red-600 dark:bg-red-500/10' : 'text-slate-600 hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-800' %>">
                <i class="fa-solid fa-chart-pie w-5 text-center"></i> نظرة عامة
            </a>
            <a href="/admin/users" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-bold <%= locals.adminTab === 'users' ? 'bg-red-50 text-red-600 dark:bg-red-500/10' : 'text-slate-600 hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-800' %>">
                <i class="fa-solid fa-users w-5 text-center"></i> المستخدمون
            </a>
            <a href="/admin/devices" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-bold <%= locals.adminTab === 'devices' ? 'bg-red-50 text-red-600 dark:bg-red-500/10' : 'text-slate-600 hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-800' %>">
                <i class="fa-solid fa-mobile-screen w-5 text-center"></i> الأجهزة
            </a>
            <div class="border-t border-slate-200 dark:border-slate-700 my-2"></div>
            <a href="/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-bold text-slate-600 hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-800">
                <i class="fa-solid fa-arrow-right-from-bracket w-5 text-center"></i> لوحة المستخدم
            </a>
        </nav>
        <div class="p-4 border-t border-slate-200 dark:border-slate-800">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-full bg-red-100 dark:bg-red-500/20 flex items-center justify-center font-bold text-red-600">
                    <i class="fa-solid fa-user-shield text-sm"></i>
                </div>
                <div>
                    <p class="text-sm font-bold"><%= user.username %></p>
                    <p class="text-xs text-red-500 font-bold">مدير النظام</p>
                </div>
            </div>
            <button onclick="logout()" class="w-full flex items-center justify-center gap-2 px-3 py-2 text-sm font-bold text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 rounded-xl transition">
                <i class="fa-solid fa-power-off"></i> تسجيل الخروج
            </button>
        </div>
    </aside>

    <!-- Main -->
    <main class="flex-1 flex flex-col overflow-hidden">
        <header class="h-16 flex items-center justify-between px-6 bg-white dark:bg-slate-900 border-b border-slate-200 dark:border-slate-800 shrink-0">
            <h1 class="text-xl font-black"><%= locals.pageTitle || 'لوحة الإدارة' %></h1>
            <button onclick="toggleDark()" class="h-9 w-9 flex items-center justify-center rounded-xl border border-slate-200 dark:border-slate-700 text-slate-500">
                <i class="fa-solid fa-moon dark:hidden"></i>
                <i class="fa-solid fa-sun hidden dark:block text-yellow-400"></i>
            </button>
        </header>
        <div class="flex-1 overflow-y-auto p-6">
