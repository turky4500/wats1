<% locals.activeTab = 'devices'; locals.pageTitle = 'الأجهزة والربط'; %>
<%- include('../partials/dashboard_sidebar') %>

<div class="flex items-center justify-between mb-5">
    <p class="text-sm text-slate-500 dark:text-slate-400"><%= devices.length %> جهاز مسجّل</p>
    <button onclick="openAddModal()"
        class="flex items-center gap-2 px-5 py-2.5 bg-[#118C7E] hover:bg-[#25D366] text-white text-sm font-black rounded-xl shadow-lg shadow-emerald-500/20 transition">
        <i class="fa-solid fa-plus"></i> إضافة جهاز
    </button>
</div>

<% if(devices.length === 0) { %>
<div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="w-20 h-20 rounded-3xl bg-slate-100 dark:bg-slate-800 flex items-center justify-center text-4xl text-slate-300 dark:text-slate-600 mb-4"><i class="fa-brands fa-whatsapp"></i></div>
    <h3 class="font-black text-lg mb-1">لا توجد أجهزة بعد</h3>
    <p class="text-slate-500 text-sm mb-5">أضف جهازاً لبدء الإرسال والربط بواتساب.</p>
    <button onclick="openAddModal()" class="px-6 py-3 bg-[#118C7E] text-white font-black rounded-xl shadow-lg shadow-emerald-500/20">
        <i class="fa-solid fa-plus ml-1"></i> إضافة جهاز
    </button>
</div>
<% } %>

<div class="grid md:grid-cols-2 gap-5">
<% devices.forEach(device => { %>
<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden">
    <!-- Header -->
    <div class="flex items-center gap-4 px-5 py-4 border-b border-slate-100 dark:border-slate-800">
        <div class="w-12 h-12 rounded-2xl <%= device.status==='connected' ? 'bg-emerald-100 dark:bg-emerald-500/10' : 'bg-slate-100 dark:bg-slate-800' %> flex items-center justify-center text-2xl">
            <i class="fa-brands fa-whatsapp <%= device.status==='connected' ? 'text-[#118C7E]' : 'text-slate-400' %>"></i>
        </div>
        <div class="flex-1 min-w-0">
            <h3 class="font-black text-slate-900 dark:text-white"><%= device.name %></h3>
            <p class="text-xs text-slate-400" id="phone-<%= device.id %>"><%= device.phone_number ? '+' + device.phone_number : 'غير مرتبط' %></p>
        </div>
        <span id="badge-<%= device.id %>" class="px-3 py-1 rounded-full text-xs font-black <%= device.status==='connected' ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500 dark:bg-slate-800 dark:text-slate-400' %>">
            <span class="inline-block w-1.5 h-1.5 rounded-full <%= device.status==='connected' ? 'bg-[#25D366]' : 'bg-slate-400' %> ml-1"></span>
            <%= device.status==='connected' ? 'متصل' : 'مفصول' %>
        </span>
    </div>

    <!-- Actions -->
    <div class="px-5 py-4">
        <% if(device.status !== 'connected') { %>
        <!-- Connect Tabs -->
        <div class="flex gap-2 mb-4">
            <button onclick="showQR(<%= device.id %>)"
                class="flex-1 py-2 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-bold hover:border-[#118C7E] hover:text-[#118C7E] transition">
                <i class="fa-solid fa-qrcode ml-1"></i> QR Code
            </button>
            <button onclick="showPairing(<%= device.id %>)"
                class="flex-1 py-2 rounded-xl border border-slate-200 dark:border-slate-700 text-sm font-bold hover:border-[#118C7E] hover:text-[#118C7E] transition">
                <i class="fa-solid fa-hashtag ml-1"></i> رمز رقمي
            </button>
        </div>

        <!-- QR Area -->
        <div id="qr-area-<%= device.id %>" class="hidden text-center py-4">
            <div class="inline-block p-3 bg-white rounded-2xl border border-slate-200 shadow-sm">
                <img id="qr-img-<%= device.id %>" src="" alt="QR" class="w-44 h-44 rounded-xl">
            </div>
            <p class="text-xs text-slate-400 mt-3 flex items-center justify-center gap-1.5">
                <i class="fa-solid fa-spinner fa-spin text-[#118C7E]"></i> في انتظار المسح من واتساب...
            </p>
        </div>

        <!-- Pairing Area -->
        <div id="pair-area-<%= device.id %>" class="hidden">
            <div class="flex gap-2">
                <input type="tel" id="pair-phone-<%= device.id %>" placeholder="966500000000"
                    class="flex-1 px-3 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 text-sm outline-none focus:border-[#118C7E]">
                <button onclick="requestPairing(<%= device.id %>)"
                    class="px-4 py-2.5 bg-[#118C7E] text-white text-sm font-black rounded-xl hover:bg-[#25D366] transition">
                    طلب
                </button>
            </div>
            <div id="code-box-<%= device.id %>" class="hidden mt-4 p-4 bg-slate-50 dark:bg-slate-800 rounded-xl text-center">
                <p class="text-xs text-slate-400 mb-2">أدخل هذا الرمز في واتساب ← الأجهزة المرتبطة ← ربط جهاز</p>
                <p id="code-val-<%= device.id %>" class="text-3xl font-black tracking-[0.3em] text-[#118C7E]"></p>
            </div>
        </div>
        <% } else { %>
        <!-- Connected actions -->
        <div class="flex items-center gap-3">
            <div class="flex-1 flex items-center gap-2 text-sm text-slate-500">
                <i class="fa-solid fa-circle-check text-[#25D366]"></i>
                مرتبط بنجاح وجاهز للإرسال
            </div>
            <button onclick="logoutDevice(<%= device.id %>)"
                class="text-xs font-bold text-red-500 hover:bg-red-50 dark:hover:bg-red-500/10 px-3 py-1.5 rounded-lg transition">
                <i class="fa-solid fa-plug-circle-xmark ml-1"></i> فصل
            </button>
        </div>
        <% } %>

        <!-- Delete -->
        <div class="mt-3 pt-3 border-t border-slate-100 dark:border-slate-800 flex justify-end">
            <button onclick="deleteDevice(<%= device.id %>)" class="text-xs text-slate-400 hover:text-red-500 transition">
                <i class="fa-solid fa-trash ml-1"></i> حذف الجهاز
            </button>
        </div>
    </div>
</div>
<% }) %>
</div>

<!-- Add Device Modal -->
<div id="addModal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-slate-900/60 backdrop-blur-sm p-4">
    <div class="bg-white dark:bg-slate-900 rounded-3xl p-7 w-full max-w-sm shadow-2xl border border-slate-200 dark:border-slate-700">
        <h3 class="text-xl font-black mb-5">إضافة جهاز جديد</h3>
        <input type="text" id="newDeviceName" placeholder="اسم الجهاز (مثال: جوال المبيعات)"
            class="w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 outline-none focus:border-[#118C7E] text-sm mb-4">
        <div class="flex gap-3">
            <button onclick="closeAddModal()" class="flex-1 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 font-bold text-sm">إلغاء</button>
            <button onclick="addDevice()" class="flex-1 py-2.5 rounded-xl bg-[#118C7E] text-white font-bold text-sm hover:bg-[#25D366] transition shadow-lg shadow-emerald-500/20">حفظ</button>
        </div>
    </div>
</div>

<script>
const socket = io();
socket.emit('join_room', '<%= user.id %>');

socket.on('qr_update', ({ deviceId, qr }) => {
    const img = document.getElementById('qr-img-' + deviceId);
    if (img) { img.src = qr; document.getElementById('qr-area-' + deviceId).classList.remove('hidden'); }
});

socket.on('status_update', ({ deviceId, status, phone }) => {
    if (status === 'connected') {
        Swal.fire({ icon: 'success', title: 'تم الربط!', text: 'رقم ' + phone + ' متصل الآن.', confirmButtonColor: '#118C7E' })
            .then(() => location.reload());
    }
});

socket.on('pairing_code_update', ({ deviceId, code }) => {
    const box = document.getElementById('code-box-' + deviceId);
    const val = document.getElementById('code-val-' + deviceId);
    if (box && val) { val.innerText = code.match(/.{1,4}/g)?.join('-') || code; box.classList.remove('hidden'); }
});

function openAddModal() { document.getElementById('addModal').classList.remove('hidden'); }
function closeAddModal() { document.getElementById('addModal').classList.add('hidden'); }

async function addDevice() {
    const name = document.getElementById('newDeviceName').value.trim();
    if (!name) return Swal.fire({ icon: 'warning', text: 'أدخل اسم الجهاز', confirmButtonColor: '#118C7E' });
    const res = await fetch('/api/devices', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name })
    });
    const data = await res.json();
    if (res.ok) location.reload();
    else Swal.fire({ icon: 'error', title: 'خطأ', text: data.error, confirmButtonColor: '#118C7E' });
}

async function showQR(id) {
    document.getElementById('qr-area-' + id)?.classList.remove('hidden');
    document.getElementById('pair-area-' + id)?.classList.add('hidden');
    await fetch('/api/devices/' + id + '/connect', { method: 'POST' });
}

function showPairing(id) {
    document.getElementById('pair-area-' + id)?.classList.remove('hidden');
    document.getElementById('qr-area-' + id)?.classList.add('hidden');
    fetch('/api/devices/' + id + '/connect', { method: 'POST' });
}

async function requestPairing(id) {
    const phone = document.getElementById('pair-phone-' + id)?.value.trim();
    if (!phone) return Swal.fire({ icon: 'warning', text: 'أدخل رقم الجوال', confirmButtonColor: '#118C7E' });
    const res = await fetch('/api/devices/' + id + '/pairing', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ phone })
    });
    const data = await res.json();
    if (!res.ok) Swal.fire({ icon: 'error', text: data.error, confirmButtonColor: '#118C7E' });
}

async function logoutDevice(id) {
    await fetch('/api/devices/' + id + '/logout', { method: 'POST' });
    location.reload();
}

async function deleteDevice(id) {
    const r = await Swal.fire({ title: 'حذف الجهاز؟', icon: 'warning', showCancelButton: true, confirmButtonColor: '#ef4444', cancelButtonText: 'إلغاء', confirmButtonText: 'حذف' });
    if (r.isConfirmed) {
        await fetch('/api/devices/' + id, { method: 'DELETE' });
        location.reload();
    }
}
</script>

<%- include('../partials/dashboard_footer') %>
