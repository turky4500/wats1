<% locals.activeTab = 'campaigns'; locals.pageTitle = 'الحملات الجماعية'; %>
<%- include('../partials/dashboard_sidebar') %>

<div class="grid lg:grid-cols-[1fr_380px] gap-6">

    <!-- Campaigns List -->
    <div class="space-y-4">
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100 dark:border-slate-800">
                <h2 class="font-black">الحملات (<%= campaigns.length %>)</h2>
            </div>
            <% if(campaigns.length === 0) { %>
            <div class="text-center py-12">
                <i class="fa-solid fa-bullhorn text-3xl text-slate-300 dark:text-slate-600 mb-3 block"></i>
                <p class="text-slate-500 text-sm">لا توجد حملات بعد. أنشئ حملتك الأولى!</p>
            </div>
            <% } else { %>
            <div class="divide-y divide-slate-100 dark:divide-slate-800">
                <% campaigns.forEach(c => { %>
                <div class="flex items-center gap-4 px-5 py-4 hover:bg-slate-50 dark:hover:bg-slate-800/30">
                    <div class="w-10 h-10 rounded-xl bg-[#118C7E]/10 flex items-center justify-center text-[#118C7E] shrink-0">
                        <i class="fa-solid fa-bullhorn text-sm"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-bold text-sm truncate"><%= c.name %></p>
                        <p class="text-xs text-slate-400 mt-0.5 truncate"><%= c.message_content?.substring(0,50) %>...</p>
                    </div>
                    <div class="text-left shrink-0">
                        <span class="block text-xs font-bold px-2.5 py-1 rounded-full <%= c.status==='completed' ? 'bg-emerald-100 text-emerald-700' : c.status==='processing' ? 'bg-blue-100 text-blue-700' : 'bg-red-100 text-red-600' %>">
                            <%= c.status==='completed' ? '✓ مكتملة' : c.status==='processing' ? '⟳ جارية' : '✕ فاشلة' %>
                        </span>
                        <p class="text-xs text-slate-400 mt-1 text-center"><%= new Date(c.created_at).toLocaleDateString('ar-SA') %></p>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>
        </div>
    </div>

    <!-- New Campaign Form -->
    <div class="space-y-4">
        <div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 p-5">
            <h3 class="font-black mb-5 flex items-center gap-2"><i class="fa-solid fa-rocket text-[#118C7E]"></i> حملة جديدة</h3>

            <% if(devices.length === 0) { %>
            <div class="p-4 rounded-xl bg-amber-50 dark:bg-amber-500/10 border border-amber-200 dark:border-amber-500/20 text-sm text-amber-800 dark:text-amber-200 mb-4">
                <i class="fa-solid fa-triangle-exclamation ml-1"></i>
                يجب <a href="/dashboard/devices" class="font-black underline">ربط جهاز واتساب</a> أولاً لإطلاق حملة.
            </div>
            <% } %>

            <form id="campForm" class="space-y-3">
                <div>
                    <label class="block text-xs font-bold mb-1 text-slate-600 dark:text-slate-400">اسم الحملة</label>
                    <input type="text" id="campName" required placeholder="مثال: عروض رمضان"
                        class="w-full px-3.5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 outline-none focus:border-[#118C7E] text-sm">
                </div>
                <div>
                    <label class="block text-xs font-bold mb-1 text-slate-600 dark:text-slate-400">الجهاز المرسل</label>
                    <select id="campDevice" required class="w-full px-3.5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 outline-none focus:border-[#118C7E] text-sm">
                        <option value="">اختر جهازاً...</option>
                        <% devices.forEach(d => { %><option value="<%= d.id %>"><%= d.name %></option><% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold mb-1 text-slate-600 dark:text-slate-400">المجموعة المستهدفة</label>
                    <select id="campGroup" required class="w-full px-3.5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 outline-none focus:border-[#118C7E] text-sm">
                        <option value="default">الافتراضية</option>
                        <% groups.forEach(g => { %><option value="<%= g.group_name %>"><%= g.group_name %></option><% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold mb-1 text-slate-600 dark:text-slate-400">نص الرسالة</label>
                    <textarea id="campMsg" rows="4" required placeholder="اكتب رسالتك هنا..."
                        class="w-full px-3.5 py-2.5 rounded-xl border border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-800 outline-none focus:border-[#118C7E] text-sm resize-none"></textarea>
                </div>
                <div>
                    <label class="block text-xs font-bold mb-1 text-slate-600 dark:text-slate-400">مرفق (صورة/ملف - اختياري)</label>
                    <input type="file" id="campFile" class="w-full text-xs text-slate-500 file:ml-3 file:px-3 file:py-1.5 file:rounded-lg file:border-0 file:bg-[#118C7E]/10 file:text-[#118C7E] file:font-bold">
                </div>
                <button type="submit" id="campBtn" <%= devices.length===0 ? 'disabled' : '' %>
                    class="w-full py-3 bg-[#118C7E] hover:bg-[#25D366] text-white font-black rounded-xl transition shadow-lg shadow-emerald-500/20 disabled:opacity-50 disabled:cursor-not-allowed">
                    <i class="fa-solid fa-paper-plane ml-1"></i> إرسال الحملة
                </button>
            </form>
        </div>
    </div>
</div>

<script>
document.getElementById('campForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('campBtn');
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin ml-1"></i> جاري الإطلاق...';
    btn.disabled = true;

    const fd = new FormData();
    fd.append('name', document.getElementById('campName').value);
    fd.append('device_id', document.getElementById('campDevice').value);
    fd.append('group_name', document.getElementById('campGroup').value);
    fd.append('message_content', document.getElementById('campMsg').value);
    const file = document.getElementById('campFile').files[0];
    if (file) fd.append('media', file);

    const res = await fetch('/api/campaigns', { method: 'POST', body: fd });
    const data = await res.json();
    if (res.ok) {
        Swal.fire({ icon: 'success', title: 'تم الإطلاق!', text: 'الحملة تعمل في الخلفية.', confirmButtonColor: '#118C7E' })
            .then(() => location.reload());
    } else {
        Swal.fire({ icon: 'error', title: 'خطأ', text: data.error, confirmButtonColor: '#118C7E' });
        btn.innerHTML = '<i class="fa-solid fa-paper-plane ml-1"></i> إرسال الحملة';
        btn.disabled = false;
    }
});
</script>

<%- include('../partials/dashboard_footer') %>
