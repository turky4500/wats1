<% locals.activeTab = 'archive'; locals.pageTitle = 'أرشيف الرسائل'; %>
<%- include('../partials/dashboard_sidebar') %>

<!-- Filters -->
<div class="flex flex-wrap items-center gap-3 mb-6">
    <form method="GET" action="/dashboard/archive" class="flex flex-wrap gap-2 items-center">
        <select name="type" class="px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm outline-none focus:border-[#118C7E]">
            <option value="">كل الأنواع</option>
            <option value="campaign" <%= type==='campaign'?'selected':'' %>>حملات</option>
            <option value="auto_reply" <%= type==='auto_reply'?'selected':'' %>>ردود تلقائية</option>
        </select>
        <select name="status" class="px-3 py-2 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 text-sm outline-none focus:border-[#118C7E]">
            <option value="">كل الحالات</option>
            <option value="sent" <%= status==='sent'?'selected':'' %>>مرسلة ✓</option>
            <option value="failed" <%= status==='failed'?'selected':'' %>>فاشلة ✕</option>
        </select>
        <button type="submit" class="px-4 py-2 bg-[#118C7E] text-white text-sm font-bold rounded-xl hover:bg-[#25D366] transition">فلترة</button>
        <a href="/dashboard/archive" class="px-4 py-2 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 text-sm font-bold rounded-xl hover:bg-slate-50 dark:hover:bg-slate-800 transition">إعادة تعيين</a>
    </form>
    <span class="mr-auto text-sm text-slate-400">إجمالي: <%= total %> رسالة</span>
</div>

<!-- Table -->
<div class="bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden shadow-sm">
    <% if(messages.length === 0) { %>
    <div class="text-center py-16">
        <i class="fa-solid fa-inbox text-4xl text-slate-300 dark:text-slate-600 mb-3 block"></i>
        <p class="text-slate-400 font-bold">لا توجد رسائل مطابقة للفلتر</p>
    </div>
    <% } else { %>
    <div class="overflow-x-auto">
        <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-slate-800/60 text-right">
                <tr>
                    <th class="px-5 py-3 font-bold text-slate-500 text-xs uppercase">#</th>
                    <th class="px-5 py-3 font-bold text-slate-500 text-xs uppercase">المستقبل</th>
                    <th class="px-5 py-3 font-bold text-slate-500 text-xs uppercase">الرسالة</th>
                    <th class="px-5 py-3 font-bold text-slate-500 text-xs uppercase">الجهاز</th>
                    <th class="px-5 py-3 font-bold text-slate-500 text-xs uppercase">النوع</th>
                    <th class="px-5 py-3 font-bold text-slate-500 text-xs uppercase">الحالة</th>
                    <th class="px-5 py-3 font-bold text-slate-500 text-xs uppercase">الوقت</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                <% messages.forEach((m, i) => { %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30 transition">
                    <td class="px-5 py-3.5 text-slate-400 text-xs"><%= (page-1)*limit + i + 1 %></td>
                    <td class="px-5 py-3.5">
                        <p class="font-bold text-slate-800 dark:text-white"><%= m.recipient_name || '—' %></p>
                        <p class="text-xs text-slate-400 font-mono mt-0.5"><%= m.recipient_phone %></p>
                    </td>
                    <td class="px-5 py-3.5 max-w-xs">
                        <p class="text-slate-700 dark:text-slate-300 line-clamp-2 text-xs leading-5"><%= m.message_content %></p>
                        <% if(m.media_url) { %><span class="inline-flex items-center gap-1 text-xs text-blue-500 mt-1"><i class="fa-solid fa-paperclip text-[10px]"></i> مرفق</span><% } %>
                    </td>
                    <td class="px-5 py-3.5 text-slate-500 text-xs"><%= m.device_name || '—' %></td>
                    <td class="px-5 py-3.5">
                        <span class="px-2 py-1 rounded-lg text-xs font-bold <%= m.type==='campaign' ? 'bg-blue-100 text-blue-700 dark:bg-blue-500/10 dark:text-blue-300' : 'bg-purple-100 text-purple-700 dark:bg-purple-500/10 dark:text-purple-300' %>">
                            <%= m.type === 'campaign' ? 'حملة' : 'رد تلقائي' %>
                        </span>
                    </td>
                    <td class="px-5 py-3.5">
                        <span class="px-2 py-1 rounded-lg text-xs font-bold <%= m.status==='sent' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-600' %>">
                            <%= m.status === 'sent' ? '✓ مرسلة' : '✕ فاشلة' %>
                        </span>
                    </td>
                    <td class="px-5 py-3.5 text-slate-400 text-xs whitespace-nowrap">
                        <%= new Date(m.sent_at).toLocaleString('ar-SA') %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <% const totalPages = Math.ceil(total / limit); %>
    <% if(totalPages > 1) { %>
    <div class="flex items-center justify-between px-5 py-4 border-t border-slate-100 dark:border-slate-800">
        <p class="text-xs text-slate-400">صفحة <%= page %> من <%= totalPages %></p>
        <div class="flex gap-2">
            <% if(page > 1) { %>
            <a href="?page=<%= page-1 %>&type=<%= type %>&status=<%= status %>" class="px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 text-sm font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition">السابق</a>
            <% } %>
            <% if(page < totalPages) { %>
            <a href="?page=<%= page+1 %>&type=<%= type %>&status=<%= status %>" class="px-3 py-1.5 rounded-lg bg-[#118C7E] text-white text-sm font-bold hover:bg-[#25D366] transition">التالي</a>
            <% } %>
        </div>
    </div>
    <% } %>
    <% } %>
</div>

<%- include('../partials/dashboard_footer') %>
